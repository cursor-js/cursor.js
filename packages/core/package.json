{
  "name": "@cursor.js/core",
  "private": false,
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/cursor.umd.cjs",
  "module": "./dist/cursor.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/cursor.js",
      "require": "./dist/cursor.umd.cjs"
    },
    "./cursor.css": "./dist/cursor.css"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "pnpm build:lib",
    "build:lib": "tsc && vite build",
    "build:demo": "vite build -c vite.config.demo.ts",
    "preview": "vite preview -c vite.config.demo.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.4"
  }
}
